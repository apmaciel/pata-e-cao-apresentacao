# =============================================================================
# PATA & CÃO — Backend Environment Variables
# Copy to .env and fill in real values before running locally.
# NEVER commit .env to version control.
# =============================================================================

# Server
PORT=8080
SHUTDOWN_TIMEOUT_SECS=30

# PostgreSQL — full connection string (overrides individual DB_* vars)
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:dev@localhost:5432/pata_cao?sslmode=disable

# Typesense (full-text provider search)
# Leave TYPESENSE_URL empty to disable search and fall back to PostgreSQL.
TYPESENSE_URL=http://localhost:8108
TYPESENSE_API_KEY=dev-api-key

# JWT Authentication
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-32-char-minimum-abcdefgh
JWT_ACCESS_EXPIRY_MINS=15
JWT_REFRESH_EXPIRY_DAYS=30

# Set to "true" when serving behind HTTPS so the refresh-token cookie carries
# the Secure attribute. Keep "false" for local http://localhost dev.
COOKIE_SECURE=false

# Password-reset token lifetime in minutes.
PASSWORD_RESET_EXPIRY_MINS=60

# Origin where the frontend is served. Used to build the recovery URL emailed
# to users (and surfaced in dev mode for local testing).
FRONTEND_URL=http://localhost:4321

# Comma-separated emails that get admin privileges at login. Case-insensitive.
# The DB role is not modified — the JWT issued at login carries role=admin
# whenever the user's email is in this list. Removing an entry revokes admin
# on the user's next token issuance (login or refresh).
ADMIN_EMAILS=

# Image Storage
# IMAGE_STORAGE_TYPE: "local" for dev, "seaweedfs" for production
IMAGE_STORAGE_TYPE=local
IMAGE_STORAGE_PATH=./data/images

# SeaweedFS (only used when IMAGE_STORAGE_TYPE=seaweedfs)
SEAWEEDFS_URL=http://localhost:8888

# Image LRU cache (number of entries kept in memory)
LRU_CACHE_SIZE=1000

# CORS — must be an exact origin (NOT "*") because the auth flow uses
# credentialed requests for the refresh-token cookie.
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60

# Migrations directory (defaults to ./migrations relative to binary)
# Set this when the binary is not run from the repo root
# MIGRATIONS_DIR=/app/migrations
