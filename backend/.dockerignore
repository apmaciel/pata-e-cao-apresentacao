# Explicit .dockerignore for backend.
# Only exclude what's not needed at build time — keep it minimal to avoid
# platform-specific exclusion quirks (especially on Windows).

# Local env files (use docker-compose env vars instead)
.env
.env.local

# Build artifacts from local dev
server
bin/
dist/
tmp/

# Test artifacts
*.test
*.out

# IDE
.vscode/
.idea/

# Air live-reload
tmp/
