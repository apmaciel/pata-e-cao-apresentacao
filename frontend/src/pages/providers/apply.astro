---
import '../../i18n.config';
import Layout from '../../layouts/Layout.astro';
import ProviderApplyForm from '../../components/ProviderApplyForm';
---

<Layout
  title="Seja um Parceiro Pet — PATA & CÃO"
  description="Cadastre-se como parceiro pet verificado da plataforma PATA & CÃO."
>
  <main class="min-h-screen bg-cream">
    <!-- Top brand bar -->
    <div class="bg-white border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex justify-center">
        <a href="/" class="flex-shrink-0">
          <img
            src="/pec-logo.jpeg"
            alt="PATA & CÃO"
            width={240}
            height={96}
            class="h-24 w-auto object-contain"
          />
        </a>
      </div>
    </div>

    <div class="py-10 sm:py-14 px-4 sm:px-6 lg:px-8">
      <ProviderApplyForm client:only="react" />
    </div>
  </main>
</Layout>
