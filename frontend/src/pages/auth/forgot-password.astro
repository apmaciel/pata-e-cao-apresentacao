---
import '../../i18n.config';
import Layout from '../../layouts/Layout.astro';
import ForgotPasswordFlow from '../../components/ForgotPasswordFlow';
---

<Layout
  title="Recuperar Senha — PATA & CÃO"
  description="Recupere o acesso à sua conta PATA & CÃO."
>
  <main class="min-h-screen bg-cream">
    <div class="bg-white border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex justify-center">
        <a href="/" class="flex-shrink-0">
          <img
            src="/pec-logo.jpeg"
            alt="PATA & CÃO"
            width={120}
            height={48}
            class="h-14 w-auto object-contain"
          />
        </a>
      </div>
    </div>

    <div class="py-12 sm:py-16 px-4 sm:px-6 lg:px-8">
      <ForgotPasswordFlow client:only="react" />
    </div>
  </main>
</Layout>
