# =============================================================================
# PATA & CÃO — Monorepo .gitignore
# Go backend + Node.js/Astro frontend
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
!.env.example
!backend/.env.example
!frontend/.env.example

# -----------------------------------------------------------------------------
# Go Backend
# -----------------------------------------------------------------------------
# Compiled binaries
backend/bin/
backend/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go test artifacts
*.test
*.out
coverage.out
coverage.html
backend/server

# Go build cache (keep go.sum)
vendor/

# Air (live reload)
backend/tmp/
tmp/

# -----------------------------------------------------------------------------
# Node.js / Astro Frontend
# -----------------------------------------------------------------------------
node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/.astro/
frontend/build/
dist/
.astro/

# npm / pnpm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Turbo
.turbo/

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local DB data volumes (Docker)
data/
postgres_data/
*.sql.bak

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*
log/

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.fleet/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Don't ignore docker-compose.yml — it's committed
# Ignore any local overrides
docker-compose.override.yml
docker-compose.local.yml

# -----------------------------------------------------------------------------
# Image Storage (local dev)
# -----------------------------------------------------------------------------
backend/data/images/
data/images/

# -----------------------------------------------------------------------------
# Test & Coverage Reports
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
junit*.xml
test-results/

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
backend/server
